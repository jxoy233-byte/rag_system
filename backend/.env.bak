 # ============ LLM (OpenAI 兼容) ============
 OPENAI_API_KEY=sk-cp-j-kWKqmK5y-IxAkxVrsCBxkzBZSIJwZ2mhWV27ZemhidtqvFnROMSRCKwuNdc46NGuYFqn_XOoHLwyzYvd7qSUAy4INeCglPxk4flDduJCio8d1W1UVQRKw
 OPENAI_BASE_URL=https://api.minimax.chat/v1
 LLM_MODEL=MiniMax-M3
 LLM_TEMPERATURE=0.3

 # ============ Embedding ============
 # 留空使用本地 BAAI/bge-m3；填写则走 OpenAI 兼容接口
 OPENAI_EMBEDDING_API_KEY=
 OPENAI_EMBEDDING_BASE_URL=
 OPENAI_EMBEDDING_MODEL=text-embedding-3-small
 # 本地 Embedding 模型（EMBEDDING_PROVIDER=local 时生效）
 EMBEDDING_PROVIDER=local
 LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
 LOCAL_EMBEDDING_DEVICE=cpu
 LOCAL_EMBEDDING_DIM=1024

 # ============ Reranker ============
 RERANK_PROVIDER=local
 LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3
 RERANK_TOP_K=20
 FINAL_TOP_K=5

 # ============ Web Search ============
 TAVILY_API_KEY=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
 ENABLE_WEB_SEARCH=true

 # ============ Server ============
 HOST=127.0.0.1
 PORT=8765
 LOG_LEVEL=INFO
 CORS_ORIGINS=http://localhost:5173,tauri://localhost

 # ============ Persistence ============
 DATA_DIR=./data
 UPLOAD_DIR=./data/uploads
 CHROMA_PERSIST_DIR=./data/chroma
 SQLITE_PATH=./data/metadata.db
 BM25_INDEX_DIR=./data/bm25

 # ============ Ingest ============
 CHUNK_SIZE=600
 CHUNK_OVERLAP=120
 MAX_UPLOAD_MB=50

 # ============ Agent ============
 ENABLE_MULTI_QUERY=true
 ENABLE_HYDE=false
 MAX_WEB_RESULTS=5
