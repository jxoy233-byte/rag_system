 # ============ LLM (OpenAI 兼容) ============
 OPENAI_API_KEY=
 OPENAI_BASE_URL=https://api.openai.com/v1
 LLM_MODEL=gpt-4o-mini
 LLM_TEMPERATURE=0.3

 # ============ Embedding ============
 # 留空使用本地 BAAI/bge-m3；填写则走 OpenAI 兼容接口
 OPENAI_EMBEDDING_API_KEY=
 OPENAI_EMBEDDING_BASE_URL=
 OPENAI_EMBEDDING_MODEL=text-embedding-3-small
 # 本地 Embedding 模型（EMBEDDING_PROVIDER=local 时生效）
 EMBEDDING_PROVIDER=local
 LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
 LOCAL_EMBEDDING_DEVICE=cpu
 LOCAL_EMBEDDING_DIM=1024

 # ============ Reranker ============
 RERANK_PROVIDER=local
 LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3
 RERANK_TOP_K=20
 FINAL_TOP_K=5

 # ============ Web Search ============
 TAVILY_API_KEY=
 ENABLE_WEB_SEARCH=true

 # ============ Server ============
 HOST=127.0.0.1
 PORT=8765
 LOG_LEVEL=INFO
 CORS_ORIGINS=http://localhost:5173,tauri://localhost

 # ============ Persistence ============
 DATA_DIR=./data
 UPLOAD_DIR=./data/uploads
 CHROMA_PERSIST_DIR=./data/chroma
 SQLITE_PATH=./data/metadata.db
 BM25_INDEX_DIR=./data/bm25

 # ============ Ingest ============
 CHUNK_SIZE=600
 CHUNK_OVERLAP=120
 MAX_UPLOAD_MB=50

 # ============ Agent ============
 ENABLE_MULTI_QUERY=true
 ENABLE_HYDE=false
 MAX_WEB_RESULTS=5

 # ============ Image Description ============
 # 留空使用本地 Qwen3-VL-2B-Instruct；填写则走 OpenAI 兼容接口
 IMAGE_DESCRIPTION_API_KEY=
 IMAGE_DESCRIPTION_BASE_URL=
 IMAGE_DESCRIPTION_MODEL=gpt-4o-mini
 # 本地 VLM 模型（无 API Key 时生效）
 LOCAL_VLM_MODEL=Qwen/Qwen3-VL-2B-Instruct
 LOCAL_VLM_PATH=
 LOCAL_VLM_DEVICE=auto
 MAX_IMAGES_PER_DOC=50
