{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rag-system",
  "version": "0.1.0",
  "identifier": "com.ragsystem.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "RAG 助手",
        "width": 80,
        "height": 80,
        "minWidth": 80,
        "minHeight": 80,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": false,
        "focus": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": true,
      "tooltip": "RAG 助手"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "通用文档问答 RAG 助手",
    "longDescription": "本地混合检索 + 联网搜索 + 多轮对话的桌面浮窗助手"
  }
}
